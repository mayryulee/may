# Netlify 배포 URL (로컬 빌드·카카오 미리보기 테스트용, 끝 슬래시 없이)
# 프로덕션: https://formayletter.netlify.app
VITE_SITE_URL=https://formayletter.netlify.app

# 카카오 지도 JavaScript 키 (Kakao Developers → 앱 → JavaScript 키)
# Web 플랫폼에 localhost, formayletter.netlify.app 등록 필요
VITE_KAKAO_MAP_APP_KEY=

# 카카오톡 공유 (별도 JavaScript 키, 없으면 지도 키로 시도)
# VITE_KAKAO_JAVASCRIPT_KEY=
